/************************************************************
 * EVALUATION RESULTS AND MANUAL REVIEW
 ************************************************************/

function getOrCreateEvaluationResultsSheet_() {
  const ss = SpreadsheetApp.getActive();
  let sheet = ss.getSheetByName(CONFIG.EVALUATION_RESULTS_SHEET_NAME);

  if (!sheet) {
    sheet = ss.insertSheet(CONFIG.EVALUATION_RESULTS_SHEET_NAME);
  }

  ensureSheetHeaders_(sheet, EVALUATION_RESULT_HEADERS);
  return sheet;
}

function readPromptRulesForCallback_(direction) {
  try {
    return readPromptRulesById_(direction);
  } catch (e) {
    const ss = SpreadsheetApp.getActive();
    const sheet = ss.getSheetByName(CONFIG.PROMPT_SHEET_NAME);
    const result = { prompt_version: '', rules: [], map: {} };

    if (!sheet || sheet.getLastRow() < 2) return result;

    let headerMap;

    try {
      headerMap = getPromptHeaderMap_(sheet);
    } catch (headerError) {
      return result;
    }
    const values = sheet.getRange(2, 1, sheet.getLastRow() - 1, sheet.getLastColumn()).getValues();
    const normalizedDirection = String(direction || '').trim().toUpperCase();

    values.forEach(row => {
      const record = rowToObject_(row, headerMap);
      const blockType = String(record.block_type || '').trim().toUpperCase();
      if (['GENERAL', 'STAGE'].indexOf(blockType) === -1) return;
      if (!isTruthy_(record.active)) return;

      const directionScope = String(record.direction_scope || 'BOTH').trim().toUpperCase();
      if (normalizedDirection && directionScope !== 'BOTH' && directionScope !== normalizedDirection) return;

      const rule = normalizeEvaluationRule_(record);
      if (!result.prompt_version && rule.prompt_version) result.prompt_version = rule.prompt_version;
      result.rules.push(rule);
      result.map[rule.rule_id] = rule;
    });

    result.rules.sort((a, b) => Number(a.rule_order || 0) - Number(b.rule_order || 0));
    return result;
  }
}

function upsertEvaluationResults_(callKey, direction, analysis) {
  const sheet = getOrCreateEvaluationResultsSheet_();
  const headerMap = getHeaderMap_(sheet);
  const promptData = readPromptRulesForCallback_(direction);
  const now = nowString_();
  const resultByRuleId = {};

  (analysis.rule_results || []).forEach(result => {
    const ruleId = String(result.rule_id || '').trim();
    if (ruleId) resultByRuleId[ruleId] = result;
  });

  const ruleIds = promptData.rules.map(rule => rule.rule_id);
  Object.keys(resultByRuleId).forEach(ruleId => {
    if (ruleIds.indexOf(ruleId) === -1) ruleIds.push(ruleId);
  });

  ruleIds.forEach(ruleId => {
    const rule = promptData.map[ruleId] || {
      prompt_version: promptData.prompt_version,
      block_type: '',
      rule_order: '',
      rule_id: ruleId,
      rule_name: 'Неизвестное правило',
      na_allowed: true
    };
    const aiResult = resultByRuleId[ruleId] || null;
    let aiReason = aiResult ? String(aiResult.reason || '') : 'AI не вернул оценку по этому правилу';
    const aiIsNa = aiResult ? normalizeBooleanForSheet_(aiResult.is_na) : '';

    if (aiResult && isTruthy_(aiIsNa) && !rule.na_allowed) {
      aiReason = '[Предупреждение: правило не допускает N/A, но AI вернул is_na = true.] ' + aiReason;
    }

    const rowIndex = findEvaluationResultRow_(sheet, headerMap, callKey, ruleId);
    const rowObj = {
      call_key: callKey,
      prompt_version: rule.prompt_version || promptData.prompt_version,
      block_type: rule.block_type || '',
      rule_order: rule.rule_order || '',
      rule_id: ruleId,
      rule_name: rule.rule_name || 'Неизвестное правило',
      ai_score: aiResult && aiResult.score !== null && aiResult.score !== undefined ? aiResult.score : '',
      ai_is_na: aiIsNa,
      ai_reason: aiReason,
      ai_evidence: aiResult ? String(aiResult.evidence || '') : '',
      ai_recommendation: aiResult ? String(aiResult.recommendation || '') : '',
      updated_at: now
    };

    if (rowIndex) {
      Object.keys(rowObj).forEach(key => setCellByHeader_(sheet, rowIndex, headerMap, key, rowObj[key]));
    } else {
      rowObj.created_at = now;
      sheet.appendRow(EVALUATION_RESULT_HEADERS.map(h => Object.prototype.hasOwnProperty.call(rowObj, h) ? rowObj[h] : ''));
    }
  });
}

function saveManualCallReview_(body) {
  const callKey = String(body.call_key || '').trim();
  if (!callKey) throw new Error('Не передан call_key для ручной проверки');

  const reviewStatus = String(body.review_status || '').trim();
  const manualComment = String(body.manual_comment || '').trim();
  const reviewer = getReviewerEmail_();
  const now = nowString_();

  const resultsSheet = getOrCreateEvaluationResultsSheet_();
  const resultsHeaderMap = getHeaderMap_(resultsSheet);
  const reviews = body.rule_reviews || [];

  reviews.forEach(review => {
    const ruleId = String(review.rule_id || '').trim();
    if (!ruleId) return;

    let rowIndex = findEvaluationResultRow_(resultsSheet, resultsHeaderMap, callKey, ruleId);

    if (!rowIndex) {
      resultsSheet.appendRow(EVALUATION_RESULT_HEADERS.map(h => {
        if (h === 'call_key') return callKey;
        if (h === 'rule_id') return ruleId;
        if (h === 'rule_name') return 'Неизвестное правило';
        if (h === 'created_at' || h === 'updated_at') return now;
        return '';
      }));
      rowIndex = resultsSheet.getLastRow();
    }

    setCellByHeader_(resultsSheet, rowIndex, resultsHeaderMap, 'manual_score', review.manual_score === null || review.manual_score === undefined ? '' : review.manual_score);
    setCellByHeader_(resultsSheet, rowIndex, resultsHeaderMap, 'manual_is_na', normalizeBooleanForSheet_(review.manual_is_na));
    setCellByHeader_(resultsSheet, rowIndex, resultsHeaderMap, 'manual_comment', String(review.manual_comment || ''));
    setCellByHeader_(resultsSheet, rowIndex, resultsHeaderMap, 'reviewer', reviewer);
    setCellByHeader_(resultsSheet, rowIndex, resultsHeaderMap, 'review_status', reviewStatus);
    setCellByHeader_(resultsSheet, rowIndex, resultsHeaderMap, 'updated_at', now);
  });

  const callsSheet = getOrCreateSheet_();
  ensureHeaders_(callsSheet);
  const callsHeaderMap = getHeaderMap_(callsSheet);
  const callRow = findRowByCallKey_(callsSheet, callsHeaderMap, callKey);

  if (callRow) {
    setCellByHeader_(callsSheet, callRow, callsHeaderMap, 'review_status', reviewStatus);
    setCellByHeader_(callsSheet, callRow, callsHeaderMap, 'manual_comment', manualComment);
    setCellByHeader_(callsSheet, callRow, callsHeaderMap, 'review_date', now);
    setCellByHeader_(callsSheet, callRow, callsHeaderMap, 'reviewer', reviewer);
    setCellByHeader_(callsSheet, callRow, callsHeaderMap, 'updated_at', now);
  }

  return {
    call_key: callKey,
    saved_rules: reviews.length
  };
}

function findEvaluationResultRow_(sheet, headerMap, callKey, ruleId) {
  const callKeyCol = headerMap.call_key;
  const ruleIdCol = headerMap.rule_id;
  if (!callKeyCol || !ruleIdCol) return null;

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return null;

  const values = sheet.getRange(2, 1, lastRow - 1, sheet.getLastColumn()).getValues();
  for (let i = 0; i < values.length; i++) {
    if (String(values[i][callKeyCol - 1] || '').trim() === callKey && String(values[i][ruleIdCol - 1] || '').trim() === ruleId) {
      return i + 2;
    }
  }

  return null;
}

function getReviewerEmail_() {
  try {
    return String(Session.getActiveUser().getEmail() || '').trim();
  } catch (e) {
    return '';
  }
}

/************************************************************
 * BITRIX TASKS
 ************************************************************/

function createBitrixTasksForProblemCalls() {
  const sheet = getOrCreateSheet_();
  ensureHeaders_(sheet);

  const headerMap = getHeaderMap_(sheet);

  getRequiredScriptProperty_(CONFIG.PROP_BITRIX_WEBHOOK_BASE_URL);
  getRequiredScriptProperty_(CONFIG.PROP_BITRIX_RESPONSIBLE_ID);

  const lastRow = sheet.getLastRow();

  if (lastRow < 2) {
    SpreadsheetApp.getActive().toast('Нет строк.');
    return;
  }

  const values = sheet.getRange(2, 1, lastRow - 1, sheet.getLastColumn()).getValues();

  let created = 0;
  let skipped = 0;
  let errors = 0;

  for (let i = 0; i < values.length; i++) {
    const rowIndex = i + 2;
    const row = values[i];

    const status = getCellByHeader_(row, headerMap, 'status');
    const isProblem = getCellByHeader_(row, headerMap, 'is_problem_call');
    const taskId = getCellByHeader_(row, headerMap, 'bitrix_task_id');

    if (status !== 'ANALYZED') {
      skipped++;
      continue;
    }

    if (!isTruthy_(isProblem)) {
      skipped++;
      continue;
    }

    if (taskId) {
      skipped++;
      continue;
    }

    try {
      createBitrixTaskForRow_(sheet, rowIndex, row, headerMap);
      created++;
    } catch (e) {
      errors++;
      setCellByHeader_(sheet, rowIndex, headerMap, 'error_text', String(e.message || e));
      setCellByHeader_(sheet, rowIndex, headerMap, 'updated_at', nowString_());
    }
  }

  SpreadsheetApp.getActive().toast(
    'Bitrix: создано ' + created + ', пропущено ' + skipped + ', ошибок ' + errors
  );
}

function createBitrixTasksForSelectedRows() {
  const sheet = getOrCreateSheet_();
  ensureHeaders_(sheet);

  const range = SpreadsheetApp.getActiveRange();

  if (!range) {
    SpreadsheetApp.getUi().alert('Выдели строки, по которым нужно создать задачи.');
    return;
  }

  const headerMap = getHeaderMap_(sheet);

  getRequiredScriptProperty_(CONFIG.PROP_BITRIX_WEBHOOK_BASE_URL);
  getRequiredScriptProperty_(CONFIG.PROP_BITRIX_RESPONSIBLE_ID);

  let created = 0;
  let errors = 0;

  for (let r = range.getRow(); r < range.getRow() + range.getNumRows(); r++) {
    if (r === 1) continue;

    const row = sheet.getRange(r, 1, 1, sheet.getLastColumn()).getValues()[0];

    try {
      createBitrixTaskForRow_(sheet, r, row, headerMap);
      created++;
    } catch (e) {
      errors++;
      setCellByHeader_(sheet, r, headerMap, 'error_text', String(e.message || e));
      setCellByHeader_(sheet, r, headerMap, 'updated_at', nowString_());
    }
  }

  SpreadsheetApp.getActive().toast(
    'Bitrix по выделенным: создано ' + created + ', ошибок ' + errors
  );
}

function createBitrixTaskForRow_(sheet, rowIndex, row, headerMap) {
  const existingTaskId = getCellByHeader_(row, headerMap, 'bitrix_task_id');

  if (existingTaskId) {
    throw new Error('Задача Bitrix уже создана: ' + existingTaskId);
  }

  const webhookBase = normalizeBitrixWebhookBase_(
    getRequiredScriptProperty_(CONFIG.PROP_BITRIX_WEBHOOK_BASE_URL)
  );

  const responsibleId = getRequiredScriptProperty_(CONFIG.PROP_BITRIX_RESPONSIBLE_ID);

  const callKey = getCellByHeader_(row, headerMap, 'call_key');
  const callDateTime = getCellByHeader_(row, headerMap, 'call_datetime');
  const direction = getCellByHeader_(row, headerMap, 'direction');
  const clientPhone = getCellByHeader_(row, headerMap, 'client_phone');
  const mangoSide = getCellByHeader_(row, headerMap, 'mango_side');
  const operatorName = getCellByHeader_(row, headerMap, 'operator_name');
  const driveUrl = getCellByHeader_(row, headerMap, 'drive_url');
  const analysisSummary = getCellByHeader_(row, headerMap, 'analysis_summary');
  const analysisScore = getCellByHeader_(row, headerMap, 'analysis_score');
  const analysisJson = getCellByHeader_(row, headerMap, 'analysis_json');
  const transcriptText = getCellByHeader_(row, headerMap, 'transcript_text');
  const problemLevel = getCellByHeader_(row, headerMap, 'problem_level');
  const mainError = getCellByHeader_(row, headerMap, 'main_error');
  const recommendedFeedback = getCellByHeader_(row, headerMap, 'recommended_feedback');
  const reviewUrl = buildCallReviewUrl_(callKey);
  const problematicRulesText = buildProblematicRulesText_(callKey, analysisJson);

  const title = 'Проверить проблемный звонок: ' + callDateTime + ' / ' + clientPhone;

  const description = [
    'Проблемный звонок по результатам AI-анализа.',
    '',
    'Дата/время: ' + callDateTime,
    'Направление: ' + direction,
    'Оператор: ' + operatorName,
    'Телефон клиента: ' + clientPhone,
    'Линия: ' + mangoSide,
    '',
    'Аудиозапись:',
    driveUrl,
    '',
    'AI-оценка: ' + analysisScore,
    'Уровень проблемы: ' + problemLevel,
    'Краткое содержание: ' + (analysisSummary || '—'),
    'Главная ошибка: ' + (mainError || '—'),
    'Рекомендация оператору: ' + (recommendedFeedback || '—'),
    '',
    'Ссылка на страницу проверки:',
    reviewUrl || '—',
    '',
    'Проблемные правила:',
    problematicRulesText || '—',
    '',
    'Транскрипт:',
    truncateText_(transcriptText || '—', 4000),
    '',
    'call_key:',
    callKey
  ].join('\n');

  const url = webhookBase + '/tasks.task.add.json';

  const payload = {
    fields: {
      TITLE: title,
      DESCRIPTION: description,
      RESPONSIBLE_ID: Number(responsibleId)
    }
  };

  const response = UrlFetchApp.fetch(url, {
    method: 'post',
    contentType: 'application/json',
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  });

  const code = response.getResponseCode();
  const body = response.getContentText();

  if (code < 200 || code >= 300) {
    throw new Error('Bitrix HTTP ' + code + ': ' + body);
  }

  const data = safeJsonParse_(body);

  if (!data) {
    throw new Error('Bitrix вернул не JSON: ' + body);
  }

  if (data.error) {
    throw new Error('Bitrix error: ' + data.error + ' ' + (data.error_description || ''));
  }

  const taskId =
    data.result &&
    data.result.task &&
    data.result.task.id
      ? data.result.task.id
      : data.result && data.result.id
        ? data.result.id
        : data.result;

  if (!taskId) {
    throw new Error('Не удалось получить ID задачи Bitrix: ' + body);
  }

  const taskUrl = buildBitrixTaskUrl_(webhookBase, responsibleId, taskId);
  const now = nowString_();

  setCellByHeader_(sheet, rowIndex, headerMap, 'bitrix_task_id', String(taskId));
  setCellByHeader_(sheet, rowIndex, headerMap, 'bitrix_task_url', taskUrl);
  setCellByHeader_(sheet, rowIndex, headerMap, 'updated_at', now);

  return {
    task_id: taskId,
    task_url: taskUrl
  };
}

function buildCallReviewUrl_(callKey) {
  try {
    return getCallbackWebAppUrl_() + '?call_key=' + encodeURIComponent(callKey);
  } catch (e) {
    return '';
  }
}

function buildProblematicRulesText_(callKey, analysisJson) {
  const analysis = safeJsonParse_(analysisJson) || {};
  const results = loadEvaluationResultsForCall_(callKey);
  const lines = [];

  results.forEach(result => {
    const score = toNumberOrBlank_(result.ai_score);
    if (score === '') return;

    const ruleMeta = findRuleMetadataById_(result.rule_id);
    const critical = ruleMeta ? toNumberOrBlank_(ruleMeta.critical_if_score_lte) : '';
    const problem = ruleMeta ? toNumberOrBlank_(ruleMeta.problem_if_score_lte) : '';
    const isProblemRule = (critical !== '' && score <= critical) || (problem !== '' && score <= problem);

    if (!isProblemRule) return;

    lines.push([
      'Правило: ' + (result.rule_name || result.rule_id),
      'Оценка: ' + score,
      'Почему: ' + (result.ai_reason || '—'),
      'Рекомендация: ' + (result.ai_recommendation || '—')
    ].join('\n'));
  });

  if (lines.length === 0 && analysis.rule_results) {
    return '';
  }

  return lines.join('\n\n');
}

function findRuleMetadataById_(ruleId) {
  const ss = SpreadsheetApp.getActive();
  const sheet = ss.getSheetByName(CONFIG.PROMPT_SHEET_NAME);
  if (!sheet || sheet.getLastRow() < 2) return null;

  const headerMap = getPromptHeaderMap_(sheet);
  const values = sheet.getRange(2, 1, sheet.getLastRow() - 1, sheet.getLastColumn()).getValues();

  for (let i = 0; i < values.length; i++) {
    const record = rowToObject_(values[i], headerMap);
    if (String(record.rule_id || '').trim() === ruleId) {
      return normalizeEvaluationRule_(record);
    }
  }

  return null;
}

function normalizeBitrixWebhookBase_(url) {
  return String(url || '').trim().replace(/\/+$/, '');
}

function buildBitrixTaskUrl_(webhookBase, responsibleId, taskId) {
  const match = String(webhookBase || '').match(/^(https?:\/\/[^/]+)/i);
  const origin = match ? match[1] : '';

  if (!origin) return '';

  return origin + '/company/personal/user/' + responsibleId + '/tasks/task/view/' + taskId + '/';
}

