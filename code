function truncateText_(text, maxLength) {
  const s = String(text || '');

  if (s.length <= maxLength) return s;

  return s.slice(0, maxLength) + '\n\n...[обрезано, всего символов: ' + s.length + ']';
}

function normalizeBooleanForSheet_(value) {
  if (value === true) return 'TRUE';
  if (value === false) return 'FALSE';

  const s = String(value || '').trim().toLowerCase();

  if (['true', '1', 'yes', 'да', 'истина'].indexOf(s) !== -1) return 'TRUE';
  if (['false', '0', 'no', 'нет', 'ложь'].indexOf(s) !== -1) return 'FALSE';

  return '';
}

function isTruthy_(value) {
  const s = String(value || '').trim().toLowerCase();
  return ['true', '1', 'yes', 'да', 'истина'].indexOf(s) !== -1;
}

/************************************************************
 * ENCODING FIX
 ************************************************************/

function shouldUseDecodedName_(original, decoded) {
  if (!decoded || original === decoded) return false;

  if (!hasSuspiciousEncodingChars_(original)) return false;

  const originalScore = filenameHumanScore_(original);
  const decodedScore = filenameHumanScore_(decoded);

  return decodedScore > originalScore;
}

function hasSuspiciousEncodingChars_(text) {
  return /[\u0300-\u036F†‡¶®©™ЂЃ§ҐґЈјЅѕЉљЊњЋћЌќЇїІіЄєµ≤≥≈∆∞±√ƒ«»…]/.test(String(text || ''));
}

function filenameHumanScore_(text) {
  const s = String(text || '');

  const russianLetters = (s.match(/[А-Яа-яЁё]/g) || []).length;
  const digits = (s.match(/\d/g) || []).length;
  const suspicious = (s.match(/[\u0300-\u036F†‡¶®©™ЂЃ§ҐґЈјЅѕЉљЊњЋћЌќЇїІіЄєµ≤≥≈∆∞±√ƒ«»…]/g) || []).length;
  const replacement = (s.match(/�/g) || []).length;

  return russianLetters * 3 + digits - suspicious * 8 - replacement * 20;
}

/**
 * Восстановление случая:
 * CP866 / DOS Cyrillic был прочитан как MacCyrillic.
 */
function decodeMacCyrillicAsCp866_(text) {
  const source = String(text || '').normalize('NFC');

  const macChars = getMacCyrillicChars128_();
  const cp866Chars = getCp866Chars128_();

  const macCharToByte = {};

  for (let i = 0; i < macChars.length; i++) {
    macCharToByte[macChars[i]] = 128 + i;
  }

  let result = '';

  for (let i = 0; i < source.length; i++) {
    const ch = source[i];
    const code = ch.charCodeAt(0);

    if (code <= 127) {
      result += ch;
      continue;
    }

    const byteValue = macCharToByte[ch];

    if (byteValue === undefined) {
      result += ch;
      continue;
    }

    result += cp866Chars[byteValue - 128] || ch;
  }

  return result;
}

