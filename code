function showScriptProperties() {
  const props = PropertiesService.getScriptProperties().getProperties();

  const keys = [
    CONFIG.PROP_N8N_WEBHOOK_URL,
    CONFIG.PROP_BITRIX_WEBHOOK_BASE_URL,
    CONFIG.PROP_BITRIX_RESPONSIBLE_ID,
    CONFIG.PROP_CALLBACK_SECRET,
    CONFIG.PROP_CALLBACK_WEBAPP_URL
  ];

  const text = keys.map(key => {
    const value = props[key] || '';
    const safeValue = key === CONFIG.PROP_CALLBACK_SECRET && value
      ? '********'
      : value;

    return key + ' = ' + safeValue;
  }).join('\n');

  SpreadsheetApp.getUi().alert('Свойства скрипта', text || 'Свойства не заданы', SpreadsheetApp.getUi().ButtonSet.OK);
}

function setScriptPropertyByPrompt_(key, title, helpText) {
  const ui = SpreadsheetApp.getUi();
  const current = PropertiesService.getScriptProperties().getProperty(key) || '';

  const response = ui.prompt(
    title,
    helpText + '\n\nТекущее значение:\n' + current,
    ui.ButtonSet.OK_CANCEL
  );

  if (response.getSelectedButton() !== ui.Button.OK) return;

  const value = String(response.getResponseText() || '').trim();

  if (!value) {
    ui.alert('Пустое значение не сохранено.');
    return;
  }

  PropertiesService.getScriptProperties().setProperty(key, value);
  SpreadsheetApp.getActive().toast('Сохранено: ' + key);
}

function getScriptProperty_(key) {
  return String(PropertiesService.getScriptProperties().getProperty(key) || '').trim();
}

function getRequiredScriptProperty_(key) {
  const value = getScriptProperty_(key);

  if (!value) {
    throw new Error('Не задано свойство скрипта: ' + key);
  }

  return value;
}

function getCallbackSecret_() {
  let secret = getScriptProperty_(CONFIG.PROP_CALLBACK_SECRET);

  if (!secret) {
    secret = 'temed_mango_calls_secret_' + Utilities.getUuid();
    PropertiesService.getScriptProperties().setProperty(CONFIG.PROP_CALLBACK_SECRET, secret);
  }

  return secret;
}

function getCallbackWebAppUrl_() {
  const manualUrl = getScriptProperty_(CONFIG.PROP_CALLBACK_WEBAPP_URL);
  if (manualUrl) return manualUrl;

  const serviceUrl = ScriptApp.getService().getUrl();
  if (serviceUrl) return serviceUrl;

  throw new Error(
    'Не удалось определить URL Web App. Разверни скрипт как Web App или задай свойство ' +
    CONFIG.PROP_CALLBACK_WEBAPP_URL
  );
}

/************************************************************
 * SCAN GOOGLE DRIVE
 ************************************************************/

function scanMangoRecordingsFolder() {
  const sheet = getOrCreateSheet_();
  ensureHeaders_(sheet);

  const headerMap = getHeaderMap_(sheet);
  const existingCallKeys = loadExistingCallKeys_(sheet, headerMap);

  const folder = DriveApp.getFolderById(CONFIG.SOURCE_FOLDER_ID);
  const files = folder.getFiles();

  let processed = 0;
  let added = 0;
  let skippedDuplicates = 0;
  let renamed = 0;
  let skippedNotMp3 = 0;
  let errors = 0;

  const rowsToAppend = [];

  while (files.hasNext() && processed < CONFIG.MAX_FILES_PER_RUN) {
    const file = files.next();
    processed++;

    try {
      const filenameRaw = file.getName();

      if (!isMp3_(filenameRaw)) {
        skippedNotMp3++;
        continue;
      }

      const filenameFixed = normalizeMangoFilename_(filenameRaw);
      const callKey = buildCallKey_(filenameFixed);

      if (!callKey) {
        errors++;
        continue;
      }

      if (existingCallKeys.has(callKey)) {
        skippedDuplicates++;

        if (CONFIG.RENAME_FILES_ON_DRIVE && filenameFixed !== filenameRaw) {
          file.setName(filenameFixed);
          renamed++;
        }

        continue;
      }

      if (CONFIG.RENAME_FILES_ON_DRIVE && filenameFixed !== filenameRaw) {
        file.setName(filenameFixed);
        renamed++;
      }

      const parsed = parseMangoFilename_(filenameFixed);
      const now = nowString_();

      const rowObj = {
        call_key: callKey,
        filename_raw: filenameRaw,
        filename_fixed: filenameFixed,

        call_datetime: parsed.call_datetime,
        call_date: parsed.call_date,
        call_time: parsed.call_time,

        direction: parsed.direction,
        client_phone: parsed.client_phone,
        mango_side: parsed.mango_side,
        line_name: parsed.line_name,
        operator_name: parsed.operator_name,

        drive_file_id: file.getId(),
        drive_url: file.getUrl(),

        status: parsed.error_text ? 'ERROR' : 'NEW',
        transcript_status: '',
        ai_status: '',
        review_status: '',

        n8n_status: '',
        n8n_sent_at: '',
        n8n_result_at: '',

        prompt_version: '',
        transcript_text: '',
        analysis_summary: '',
        analysis_json: '',
        analysis_score: '',
        is_problem_call: '',

        bitrix_task_id: '',
        bitrix_task_url: '',

        error_text: parsed.error_text,
        created_at: now,
        updated_at: now
      };

      rowsToAppend.push(makeRowByHeaders_(rowObj));
      existingCallKeys.add(callKey);
      added++;

    } catch (e) {
      errors++;
      Logger.log('Ошибка обработки файла: ' + e.stack);
    }
  }

  if (rowsToAppend.length > 0) {
    sheet
      .getRange(sheet.getLastRow() + 1, 1, rowsToAppend.length, HEADERS.length)
      .setValues(rowsToAppend);
  }

  const message =
    'Готово. Обработано: ' + processed +
    ', добавлено: ' + added +
    ', дублей пропущено: ' + skippedDuplicates +
    ', переименовано: ' + renamed +
    ', не mp3: ' + skippedNotMp3 +
    ', ошибок: ' + errors;

  SpreadsheetApp.getActive().toast(message);
  Logger.log(message);
}

/************************************************************
 * PARSE MANGO FILENAME
 ************************************************************/

function normalizeMangoFilename_(filename) {
  const original = String(filename || '').normalize('NFC');
  const decoded = decodeMacCyrillicAsCp866_(original);

  if (shouldUseDecodedName_(original, decoded)) {
    return sanitizeDriveFilename_(decoded);
  }

  return sanitizeDriveFilename_(original);
}

function buildCallKey_(filenameFixed) {
  const base = stripExtension_(filenameFixed).trim();

  if (!base) return '';

  return base
    .replace(/\s+/g, ' ')
    .trim();
}

/**
 * Форматы:
 *
 * OUTBOUND / мы звоним:
 * 2026-06-05__10-27-54__Продажи 2 Шкляр А__79378511104.mp3
 *
 * INBOUND / нам звонят:
 * 2026-06-05__10-40-03__79203381996__Продажи 4 Солопова О.mp3
 */
function parseMangoFilename_(filenameFixed) {
  const base = stripExtension_(filenameFixed);
  const parts = base.split('__').map(p => String(p || '').trim());

  const result = {
    call_datetime: '',
    call_date: '',
    call_time: '',

    direction: '',
    client_phone: '',
    mango_side: '',
    line_name: '',
    operator_name: '',

    error_text: ''
  };

  if (parts.length < 4) {
    result.error_text = 'Не удалось разобрать имя файла: ожидается минимум 4 блока через "__"';
    return result;
  }

  const datePart = parts[0];
  const timePartRaw = parts[1];
  const timePart = timePartRaw.replace(/-/g, ':');

  result.call_date = datePart;
  result.call_time = timePart;
  result.call_datetime = datePart + ' ' + timePart;

  const payloadParts = parts.slice(2);

  const firstPayload = payloadParts[0];
  const lastPayload = payloadParts[payloadParts.length - 1];

  const firstIsPhone = isPhone_(firstPayload);
  const lastIsPhone = isPhone_(lastPayload);

  if (firstIsPhone && !lastIsPhone) {
    result.direction = 'INBOUND';
    result.client_phone = firstPayload;
    result.mango_side = payloadParts.slice(1).join('__').trim();

  } else if (!firstIsPhone && lastIsPhone) {
    result.direction = 'OUTBOUND';
    result.client_phone = lastPayload;
    result.mango_side = payloadParts.slice(0, payloadParts.length - 1).join('__').trim();

  } else if (firstIsPhone && lastIsPhone) {
    result.error_text = 'Неоднозначное имя файла: телефон найден и в начале, и в конце блока после времени';
    return result;

  } else {
    result.error_text = 'Не найден телефон клиента ни в начале, ни в конце блока после времени';
    return result;
  }

  const sideParsed = parseMangoSide_(result.mango_side);

  result.line_name = sideParsed.line_name;
  result.operator_name = sideParsed.operator_name;

  const problems = [];

  if (!/^\d{4}-\d{2}-\d{2}$/.test(datePart)) {
    problems.push('Некорректная дата: ' + datePart);
  }

  if (!/^\d{2}:\d{2}:\d{2}$/.test(timePart)) {
    problems.push('Некорректное время: ' + timePartRaw);
  }

  if (!result.client_phone || !isPhone_(result.client_phone)) {
    problems.push('Некорректный телефон клиента: ' + result.client_phone);
  }

  if (!result.mango_side) {
    problems.push('Не определена наша сторона звонка');
  }

  if (!result.direction) {
    problems.push('Не определено направление звонка');
  }

  result.error_text = problems.join('; ');

  return result;
}

function parseMangoSide_(mangoSide) {
  const text = String(mangoSide || '').trim();
  const tokens = text.split(/\s+/).filter(Boolean);

  const result = {
    line_name: text,
    operator_name: ''
  };

  if (tokens.length >= 3) {
    result.operator_name = tokens.slice(-2).join(' ');
    result.line_name = tokens.slice(0, -2).join(' ');
  }

  return result;
}

/************************************************************
 * PROMPT CONFIG
 ************************************************************/

function readPromptConfig_() {
  const ss = SpreadsheetApp.getActive();
  const sheet = ss.getSheetByName(CONFIG.PROMPT_SHEET_NAME);

  if (!sheet) {
    throw new Error('Не найден лист "' + CONFIG.PROMPT_SHEET_NAME + '". Сначала создай его через меню.');
  }

  const lastRow = sheet.getLastRow();

  if (lastRow < 2) {
    throw new Error('Лист "' + CONFIG.PROMPT_SHEET_NAME + '" пустой.');
  }

  const values = sheet.getRange(2, 1, lastRow - 1, 2).getValues();
  const config = {};

  values.forEach(row => {
    const key = String(row[0] || '').trim();
    const value = String(row[1] || '').trim();

    if (key) {
      config[key] = value;
    }
  });

  if (!config.prompt_version) {
    throw new Error('На листе "Промпт" не заполнен ключ prompt_version.');
  }

  if (!config.transcription_prompt) {
    throw new Error('На листе "Промпт" не заполнен ключ transcription_prompt.');
  }

  if (!config.analysis_prompt) {
    throw new Error('На листе "Промпт" не заполнен ключ analysis_prompt.');
  }

  return config;
}

/************************************************************
 * SEND TO N8N
 ************************************************************/

function sendNewCallsToN8n() {
  const sheet = getOrCreateSheet_();
  ensureHeaders_(sheet);

  const headerMap = getHeaderMap_(sheet);
  const promptConfig = readPromptConfig_();

  getRequiredScriptProperty_(CONFIG.PROP_N8N_WEBHOOK_URL);
  getCallbackSecret_();
  getCallbackWebAppUrl_();

  const lastRow = sheet.getLastRow();

  if (lastRow < 2) {
    SpreadsheetApp.getActive().toast('Нет строк для отправки.');
    return;
  }

  const values = sheet.getRange(2, 1, lastRow - 1, sheet.getLastColumn()).getValues();

  let sent = 0;
  let skipped = 0;
  let errors = 0;

  for (let i = 0; i < values.length; i++) {
    if (sent >= CONFIG.MAX_SEND_TO_N8N_PER_RUN) break;

    const rowIndex = i + 2;
    const row = values[i];

    const status = getCellByHeader_(row, headerMap, 'status');
    const n8nStatus = getCellByHeader_(row, headerMap, 'n8n_status');
    const errorText = getCellByHeader_(row, headerMap, 'error_text');

    if (errorText) {
      skipped++;
      continue;
    }

    if (status !== 'NEW') {
      skipped++;
      continue;
    }

    if (n8nStatus === 'SENT_TO_N8N' || n8nStatus === 'ANALYZED') {
      skipped++;
      continue;
    }

    try {
      sendRowToN8n_(sheet, rowIndex, row, headerMap, promptConfig);
      sent++;
    } catch (e) {
      errors++;
      setCellByHeader_(sheet, rowIndex, headerMap, 'n8n_status', 'N8N_ERROR');
      setCellByHeader_(sheet, rowIndex, headerMap, 'status', 'N8N_ERROR');
      setCellByHeader_(sheet, rowIndex, headerMap, 'error_text', String(e.message || e));
      setCellByHeader_(sheet, rowIndex, headerMap, 'updated_at', nowString_());
    }
  }

  SpreadsheetApp.getActive().toast(
    'Отправка в n8n завершена. Отправлено: ' + sent +
    ', пропущено: ' + skipped +
    ', ошибок: ' + errors
  );
}

function sendSelectedRowsToN8n() {
  const sheet = getOrCreateSheet_();
  ensureHeaders_(sheet);

  const range = SpreadsheetApp.getActiveRange();

  if (!range) {
    SpreadsheetApp.getUi().alert('Выдели строки, которые нужно отправить в n8n.');
    return;
  }

  const headerMap = getHeaderMap_(sheet);
  const promptConfig = readPromptConfig_();

  getRequiredScriptProperty_(CONFIG.PROP_N8N_WEBHOOK_URL);
  getCallbackSecret_();
  getCallbackWebAppUrl_();

  const startRow = range.getRow();
  const numRows = range.getNumRows();

  let sent = 0;
  let errors = 0;

  for (let r = startRow; r < startRow + numRows; r++) {
    if (r === 1) continue;

    const row = sheet.getRange(r, 1, 1, sheet.getLastColumn()).getValues()[0];

    try {
      const errorText = getCellByHeader_(row, headerMap, 'error_text');

      if (errorText) {
        throw new Error('Строка содержит ошибку парсинга: ' + errorText);
      }

      sendRowToN8n_(sheet, r, row, headerMap, promptConfig);
      sent++;
    } catch (e) {
      errors++;
      setCellByHeader_(sheet, r, headerMap, 'n8n_status', 'N8N_ERROR');
      setCellByHeader_(sheet, r, headerMap, 'status', 'N8N_ERROR');
      setCellByHeader_(sheet, r, headerMap, 'error_text', String(e.message || e));
      setCellByHeader_(sheet, r, headerMap, 'updated_at', nowString_());
    }
  }

  SpreadsheetApp.getActive().toast(
    'Выделенные строки отправлены. Отправлено: ' + sent + ', ошибок: ' + errors
  );
}

function sendRowToN8n_(sheet, rowIndex, row, headerMap, promptConfig) {
  const n8nWebhookUrl = getRequiredScriptProperty_(CONFIG.PROP_N8N_WEBHOOK_URL);
  const callbackSecret = getCallbackSecret_();
  const callbackUrl = getCallbackWebAppUrl_();

  const payload = {
    action: 'transcribe_and_analyze_call',
    secret: callbackSecret,

    call_key: getCellByHeader_(row, headerMap, 'call_key'),
    filename_fixed: getCellByHeader_(row, headerMap, 'filename_fixed'),

    call_datetime: getCellByHeader_(row, headerMap, 'call_datetime'),
    call_date: getCellByHeader_(row, headerMap, 'call_date'),
    call_time: getCellByHeader_(row, headerMap, 'call_time'),

    direction: getCellByHeader_(row, headerMap, 'direction'),
    client_phone: getCellByHeader_(row, headerMap, 'client_phone'),
    mango_side: getCellByHeader_(row, headerMap, 'mango_side'),
    line_name: getCellByHeader_(row, headerMap, 'line_name'),
    operator_name: getCellByHeader_(row, headerMap, 'operator_name'),

    drive_file_id: getCellByHeader_(row, headerMap, 'drive_file_id'),
    drive_url: getCellByHeader_(row, headerMap, 'drive_url'),

    prompt_version: promptConfig.prompt_version,

    prompts: {
      transcription_prompt: promptConfig.transcription_prompt,
      analysis_prompt: promptConfig.analysis_prompt,
      output_schema: promptConfig.output_schema || ''
    },

    callback: {
      url: callbackUrl,
      secret: callbackSecret
    }
  };

  if (!payload.call_key) {
    throw new Error('В строке нет call_key');
  }

  if (!payload.drive_file_id) {
    throw new Error('В строке нет drive_file_id');
  }

  const response = UrlFetchApp.fetch(n8nWebhookUrl, {
    method: 'post',
    contentType: 'application/json',
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  });

  const code = response.getResponseCode();
  const body = response.getContentText();

  if (code < 200 || code >= 300) {
    throw new Error('n8n вернул HTTP ' + code + ': ' + body);
  }

  const now = nowString_();

  setCellByHeader_(sheet, rowIndex, headerMap, 'status', 'SENT_TO_N8N');
  setCellByHeader_(sheet, rowIndex, headerMap, 'n8n_status', 'SENT_TO_N8N');
  setCellByHeader_(sheet, rowIndex, headerMap, 'n8n_sent_at', now);
  setCellByHeader_(sheet, rowIndex, headerMap, 'prompt_version', promptConfig.prompt_version);
  setCellByHeader_(sheet, rowIndex, headerMap, 'error_text', '');
  setCellByHeader_(sheet, rowIndex, headerMap, 'updated_at', now);
}

/************************************************************
 * CALLBACK FROM N8N
 ************************************************************/

function doPost(e) {
  try {
    const body = JSON.parse((e && e.postData && e.postData.contents) || '{}');

    const expectedSecret = getCallbackSecret_();

    if (body.secret !== expectedSecret) {
      return jsonResponse_({
        ok: false,
        error: 'Forbidden: bad secret'
      });
    }

    if (body.action === 'ping') {
      return jsonResponse_({
        ok: true,
        message: 'pong'
      });
    }

    if (body.action === 'n8n_call_result') {
      const result = saveN8nCallResult_(body);

      return jsonResponse_({
        ok: true,
        result: result
      });
    }

    if (body.action === 'n8n_call_error') {
      const result = saveN8nCallError_(body);

      return jsonResponse_({
        ok: true,
        result: result
      });
    }

    return jsonResponse_({
      ok: false,
      error: 'Unknown action: ' + body.action
    });

  } catch (err) {
    return jsonResponse_({
      ok: false,
      error: String(err.message || err)
    });
  }
}

function doGet() {
  return jsonResponse_({
    ok: true,
    service: 'Mango calls callback',
    time: nowString_()
  });
}

function saveN8nCallResult_(body) {
  const sheet = getOrCreateSheet_();
  ensureHeaders_(sheet);

  const headerMap = getHeaderMap_(sheet);
  const callKey = String(body.call_key || '').trim();

  if (!callKey) {
    throw new Error('В callback нет call_key');
  }

  const rowIndex = findRowByCallKey_(sheet, headerMap, callKey);

  if (!rowIndex) {
    throw new Error('Не найдена строка по call_key: ' + callKey);
  }

  const now = nowString_();

  const transcriptText = String(body.transcript_text || '');

  let analysis = body.analysis || {};

  if (typeof analysis === 'string') {
    analysis = safeJsonParse_(analysis) || {
      raw: analysis
    };
  }

  const analysisJson = JSON.stringify(analysis, null, 2);

  const summary = String(
    analysis.summary ||
    body.analysis_summary ||
    ''
  );

  const score = String(
    analysis.score_1_5 ||
    analysis.score ||
    body.analysis_score ||
    ''
  );

  const isProblem = normalizeBooleanForSheet_(
    analysis.is_problem_call !== undefined
      ? analysis.is_problem_call
      : body.is_problem_call
  );

  setCellByHeader_(sheet, rowIndex, headerMap, 'transcript_text', transcriptText);
  setCellByHeader_(sheet, rowIndex, headerMap, 'analysis_json', analysisJson);
  setCellByHeader_(sheet, rowIndex, headerMap, 'analysis_summary', summary);
  setCellByHeader_(sheet, rowIndex, headerMap, 'analysis_score', score);
  setCellByHeader_(sheet, rowIndex, headerMap, 'is_problem_call', isProblem);

  setCellByHeader_(sheet, rowIndex, headerMap, 'transcript_status', transcriptText ? 'OK' : '');
  setCellByHeader_(sheet, rowIndex, headerMap, 'ai_status', analysisJson ? 'OK' : '');

  setCellByHeader_(sheet, rowIndex, headerMap, 'n8n_status', 'ANALYZED');
  setCellByHeader_(sheet, rowIndex, headerMap, 'status', 'ANALYZED');
  setCellByHeader_(sheet, rowIndex, headerMap, 'n8n_result_at', now);
  setCellByHeader_(sheet, rowIndex, headerMap, 'error_text', '');
  setCellByHeader_(sheet, rowIndex, headerMap, 'updated_at', now);

  return {
    call_key: callKey,
    row: rowIndex
  };
}

function saveN8nCallError_(body) {
  const sheet = getOrCreateSheet_();
  ensureHeaders_(sheet);

  const headerMap = getHeaderMap_(sheet);
  const callKey = String(body.call_key || '').trim();

  if (!callKey) {
    throw new Error('В callback error нет call_key');
  }

  const rowIndex = findRowByCallKey_(sheet, headerMap, callKey);

  if (!rowIndex) {
    throw new Error('Не найдена строка по call_key: ' + callKey);
  }

  const now = nowString_();

  setCellByHeader_(sheet, rowIndex, headerMap, 'n8n_status', 'N8N_ERROR');
  setCellByHeader_(sheet, rowIndex, headerMap, 'status', 'N8N_ERROR');
  setCellByHeader_(sheet, rowIndex, headerMap, 'error_text', String(body.error_text || body.error || 'Ошибка n8n'));
  setCellByHeader_(sheet, rowIndex, headerMap, 'n8n_result_at', now);
  setCellByHeader_(sheet, rowIndex, headerMap, 'updated_at', now);

  return {
    call_key: callKey,
    row: rowIndex
  };
}

/************************************************************
 * BITRIX TASKS
 ************************************************************/

function createBitrixTasksForProblemCalls() {
  const sheet = getOrCreateSheet_();
  ensureHeaders_(sheet);

  const headerMap = getHeaderMap_(sheet);

  getRequiredScriptProperty_(CONFIG.PROP_BITRIX_WEBHOOK_BASE_URL);
  getRequiredScriptProperty_(CONFIG.PROP_BITRIX_RESPONSIBLE_ID);

  const lastRow = sheet.getLastRow();

  if (lastRow < 2) {
    SpreadsheetApp.getActive().toast('Нет строк.');
    return;
  }

  const values = sheet.getRange(2, 1, lastRow - 1, sheet.getLastColumn()).getValues();

  let created = 0;
  let skipped = 0;
  let errors = 0;

  for (let i = 0; i < values.length; i++) {
    const rowIndex = i + 2;
    const row = values[i];

    const status = getCellByHeader_(row, headerMap, 'status');
    const isProblem = getCellByHeader_(row, headerMap, 'is_problem_call');
    const taskId = getCellByHeader_(row, headerMap, 'bitrix_task_id');

    if (status !== 'ANALYZED') {
      skipped++;
      continue;
    }

    if (!isTruthy_(isProblem)) {
      skipped++;
      continue;
    }

    if (taskId) {
      skipped++;
      continue;
    }

    try {
      createBitrixTaskForRow_(sheet, rowIndex, row, headerMap);
      created++;
    } catch (e) {
      errors++;
      setCellByHeader_(sheet, rowIndex, headerMap, 'error_text', String(e.message || e));
      setCellByHeader_(sheet, rowIndex, headerMap, 'updated_at', nowString_());
    }
  }

  SpreadsheetApp.getActive().toast(
    'Bitrix: создано ' + created + ', пропущено ' + skipped + ', ошибок ' + errors
  );
}

function createBitrixTasksForSelectedRows() {
  const sheet = getOrCreateSheet_();
  ensureHeaders_(sheet);

  const range = SpreadsheetApp.getActiveRange();

  if (!range) {
    SpreadsheetApp.getUi().alert('Выдели строки, по которым нужно создать задачи.');
    return;
  }

  const headerMap = getHeaderMap_(sheet);

  getRequiredScriptProperty_(CONFIG.PROP_BITRIX_WEBHOOK_BASE_URL);
  getRequiredScriptProperty_(CONFIG.PROP_BITRIX_RESPONSIBLE_ID);

  let created = 0;
  let errors = 0;

  for (let r = range.getRow(); r < range.getRow() + range.getNumRows(); r++) {
    if (r === 1) continue;

    const row = sheet.getRange(r, 1, 1, sheet.getLastColumn()).getValues()[0];

    try {
      createBitrixTaskForRow_(sheet, r, row, headerMap);
      created++;
    } catch (e) {
      errors++;
      setCellByHeader_(sheet, r, headerMap, 'error_text', String(e.message || e));
      setCellByHeader_(sheet, r, headerMap, 'updated_at', nowString_());
    }
  }

  SpreadsheetApp.getActive().toast(
    'Bitrix по выделенным: создано ' + created + ', ошибок ' + errors
  );
}

function createBitrixTaskForRow_(sheet, rowIndex, row, headerMap) {
  const existingTaskId = getCellByHeader_(row, headerMap, 'bitrix_task_id');

  if (existingTaskId) {
    throw new Error('Задача Bitrix уже создана: ' + existingTaskId);
  }

  const webhookBase = normalizeBitrixWebhookBase_(
    getRequiredScriptProperty_(CONFIG.PROP_BITRIX_WEBHOOK_BASE_URL)
  );

  const responsibleId = getRequiredScriptProperty_(CONFIG.PROP_BITRIX_RESPONSIBLE_ID);

  const callKey = getCellByHeader_(row, headerMap, 'call_key');
  const callDateTime = getCellByHeader_(row, headerMap, 'call_datetime');
  const direction = getCellByHeader_(row, headerMap, 'direction');
  const clientPhone = getCellByHeader_(row, headerMap, 'client_phone');
  const mangoSide = getCellByHeader_(row, headerMap, 'mango_side');
  const operatorName = getCellByHeader_(row, headerMap, 'operator_name');
  const driveUrl = getCellByHeader_(row, headerMap, 'drive_url');
  const analysisSummary = getCellByHeader_(row, headerMap, 'analysis_summary');
  const analysisScore = getCellByHeader_(row, headerMap, 'analysis_score');
  const analysisJson = getCellByHeader_(row, headerMap, 'analysis_json');
  const transcriptText = getCellByHeader_(row, headerMap, 'transcript_text');

  const title = 'Проверить проблемный звонок: ' + callDateTime + ' / ' + clientPhone;

  const description = [
    'Проблемный звонок по результатам AI-анализа.',
    '',
    'Дата/время: ' + callDateTime,
    'Направление: ' + direction,
    'Клиентский телефон: ' + clientPhone,
    'Наша сторона: ' + mangoSide,
    'Оператор: ' + operatorName,
    '',
    'Аудиозапись:',
    driveUrl,
    '',
    'Оценка AI: ' + analysisScore,
    '',
    'Краткое резюме:',
    analysisSummary || '—',
    '',
    'JSON анализа:',
    truncateText_(analysisJson || '—', 4000),
    '',
    'Транскрипт:',
    truncateText_(transcriptText || '—', 4000),
    '',
    'call_key:',
    callKey
  ].join('\n');

  const url = webhookBase + '/tasks.task.add.json';

  const payload = {
    fields: {
      TITLE: title,
      DESCRIPTION: description,
      RESPONSIBLE_ID: Number(responsibleId)
    }
  };

  const response = UrlFetchApp.fetch(url, {
    method: 'post',
    contentType: 'application/json',
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  });

  const code = response.getResponseCode();
  const body = response.getContentText();

  if (code < 200 || code >= 300) {
    throw new Error('Bitrix HTTP ' + code + ': ' + body);
  }

  const data = safeJsonParse_(body);

  if (!data) {
    throw new Error('Bitrix вернул не JSON: ' + body);
  }

  if (data.error) {
    throw new Error('Bitrix error: ' + data.error + ' ' + (data.error_description || ''));
  }

  const taskId =
    data.result &&
    data.result.task &&
    data.result.task.id
      ? data.result.task.id
      : data.result && data.result.id
        ? data.result.id
        : data.result;

  if (!taskId) {
    throw new Error('Не удалось получить ID задачи Bitrix: ' + body);
  }

  const taskUrl = buildBitrixTaskUrl_(webhookBase, responsibleId, taskId);
  const now = nowString_();

  setCellByHeader_(sheet, rowIndex, headerMap, 'bitrix_task_id', String(taskId));
  setCellByHeader_(sheet, rowIndex, headerMap, 'bitrix_task_url', taskUrl);
  setCellByHeader_(sheet, rowIndex, headerMap, 'updated_at', now);

  return {
    task_id: taskId,
    task_url: taskUrl
  };
}

function normalizeBitrixWebhookBase_(url) {
  return String(url || '').trim().replace(/\/+$/, '');
}

function buildBitrixTaskUrl_(webhookBase, responsibleId, taskId) {
  const match = String(webhookBase || '').match(/^(https?:\/\/[^/]+)/i);
  const origin = match ? match[1] : '';

  if (!origin) return '';

  return origin + '/company/personal/user/' + responsibleId + '/tasks/task/view/' + taskId + '/';
}

