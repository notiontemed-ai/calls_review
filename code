function setupMangoCallsSheet() {
  const sheet = getOrCreateSheet_();
  ensureHeaders_(sheet);
  SpreadsheetApp.getActive().toast('Лист проверен: ' + CONFIG.SHEET_NAME);
}

function resetMangoCallsSheet() {
  const ui = SpreadsheetApp.getUi();
  const response = ui.alert(
    'Пересоздать лист?',
    'Лист "' + CONFIG.SHEET_NAME + '" будет полностью очищен и создан заново.',
    ui.ButtonSet.YES_NO
  );

  if (response !== ui.Button.YES) return;

  const ss = SpreadsheetApp.getActive();
  let sheet = ss.getSheetByName(CONFIG.SHEET_NAME);

  if (!sheet) {
    sheet = ss.insertSheet(CONFIG.SHEET_NAME);
  } else {
    sheet.clear();
  }

  sheet.getRange(1, 1, 1, HEADERS.length).setValues([HEADERS]);
  sheet.setFrozenRows(1);
  sheet.autoResizeColumns(1, Math.min(HEADERS.length, 12));

  SpreadsheetApp.getActive().toast('Лист пересоздан.');
}

