function getOrCreateSheet_() {
  const ss = SpreadsheetApp.getActive();
  let sheet = ss.getSheetByName(CONFIG.SHEET_NAME);

  if (!sheet) {
    sheet = ss.insertSheet(CONFIG.SHEET_NAME);
  }

  return sheet;
}

function ensureHeaders_(sheet) {
  const lastRow = sheet.getLastRow();
  const lastColumn = sheet.getLastColumn();

  if (lastRow === 0 || lastColumn === 0) {
    sheet.getRange(1, 1, 1, HEADERS.length).setValues([HEADERS]);
    sheet.setFrozenRows(1);
    return;
  }

  const firstRow = sheet
    .getRange(1, 1, 1, Math.max(lastColumn, HEADERS.length))
    .getValues()[0]
    .map(String)
    .map(s => s.trim());

  const existingHeaders = firstRow.filter(Boolean);

  if (existingHeaders.length === 0) {
    sheet.getRange(1, 1, 1, HEADERS.length).setValues([HEADERS]);
    sheet.setFrozenRows(1);
    return;
  }

  const missing = HEADERS.filter(h => existingHeaders.indexOf(h) === -1);

  if (missing.length > 0) {
    sheet
      .getRange(1, existingHeaders.length + 1, 1, missing.length)
      .setValues([missing]);
  }

  sheet.setFrozenRows(1);
}

function ensureSheetHeaders_(sheet, headers) {
  const lastRow = sheet.getLastRow();
  const lastColumn = sheet.getLastColumn();

  if (lastRow === 0 || lastColumn === 0) {
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
    sheet.setFrozenRows(1);
    return;
  }

  const firstRow = sheet
    .getRange(1, 1, 1, Math.max(lastColumn, headers.length))
    .getValues()[0]
    .map(String)
    .map(s => s.trim());

  const existingHeaders = firstRow.filter(Boolean);

  if (existingHeaders.length === 0) {
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
    sheet.setFrozenRows(1);
    return;
  }

  const missing = headers.filter(h => existingHeaders.indexOf(h) === -1);

  if (missing.length > 0) {
    sheet
      .getRange(1, existingHeaders.length + 1, 1, missing.length)
      .setValues([missing]);
  }

  sheet.setFrozenRows(1);
}

function getHeaderMap_(sheet) {
  const headers = sheet
    .getRange(1, 1, 1, sheet.getLastColumn())
    .getValues()[0]
    .map(String)
    .map(s => s.trim());

  const map = {};

  headers.forEach((h, index) => {
    if (h) map[h] = index + 1;
  });

  return map;
}

function loadExistingCallKeys_(sheet, headerMap) {
  const set = new Set();

  const callKeyCol = headerMap.call_key;
  if (!callKeyCol) return set;

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return set;

  const values = sheet
    .getRange(2, callKeyCol, lastRow - 1, 1)
    .getValues();

  values.forEach(row => {
    const key = String(row[0] || '').trim();
    if (key) set.add(key);
  });

  return set;
}

function makeRowByHeaders_(obj) {
  return HEADERS.map(h => {
    return Object.prototype.hasOwnProperty.call(obj, h) ? obj[h] : '';
  });
}

function getCellByHeader_(row, headerMap, headerName) {
  const col = headerMap[headerName];

  if (!col) return '';

  return String(row[col - 1] || '').trim();
}

function setCellByHeader_(sheet, rowIndex, headerMap, headerName, value) {
  const col = headerMap[headerName];

  if (!col) {
    throw new Error('Не найдена колонка: ' + headerName);
  }

  sheet.getRange(rowIndex, col).setValue(value);
}

function findRowByCallKey_(sheet, headerMap, callKey) {
  const col = headerMap.call_key;

  if (!col) {
    throw new Error('Нет колонки call_key');
  }

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return null;

  const values = sheet.getRange(2, col, lastRow - 1, 1).getValues();

  for (let i = 0; i < values.length; i++) {
    if (String(values[i][0] || '').trim() === callKey) {
      return i + 2;
    }
  }

  return null;
}

function rowToObject_(row, headerMap) {
  const obj = {};

  Object.keys(headerMap).forEach(header => {
    obj[header] = row[headerMap[header] - 1];
  });

  return obj;
}

function toNumberOrBlank_(value) {
  if (value === '' || value === null || value === undefined) return '';
  const n = Number(String(value).replace(',', '.'));
  return isNaN(n) ? '' : n;
}

