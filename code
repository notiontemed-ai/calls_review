/************************************************************
 * CALLBACK FROM N8N
 ************************************************************/

function doPost(e) {
  try {
    const body = JSON.parse((e && e.postData && e.postData.contents) || '{}');

    const expectedSecret = getCallbackSecret_();

    if (body.secret !== expectedSecret) {
      return jsonResponse_({
        ok: false,
        error: 'Forbidden: bad secret'
      });
    }

    if (body.action === 'ping') {
      return jsonResponse_({
        ok: true,
        message: 'pong'
      });
    }

    if (body.action === 'n8n_call_result') {
      const result = saveN8nCallResult_(body);

      return jsonResponse_({
        ok: true,
        result: result
      });
    }

    if (body.action === 'save_manual_call_review') {
      const result = saveManualCallReview_(body);

      return jsonResponse_({
        ok: true,
        result: result
      });
    }

    if (body.action === 'n8n_call_error') {
      const result = saveN8nCallError_(body);

      return jsonResponse_({
        ok: true,
        result: result
      });
    }

    return jsonResponse_({
      ok: false,
      error: 'Unknown action: ' + body.action
    });

  } catch (err) {
    return jsonResponse_({
      ok: false,
      error: String(err.message || err)
    });
  }
}

function doGet(e) {
  const callKey = String(e && e.parameter && e.parameter.call_key || '').trim();
  const html = callKey ? renderCallReviewPage_(callKey) : renderAnalyzedCallsListPage_();

  return HtmlService
    .createHtmlOutput(html)
    .setTitle(callKey ? 'Проверка звонка' : 'Последние проанализированные звонки');
}

function saveN8nCallResult_(body) {
  const sheet = getOrCreateSheet_();
  ensureHeaders_(sheet);

  const headerMap = getHeaderMap_(sheet);
  const callKey = String(body.call_key || '').trim();

  if (!callKey) {
    throw new Error('В callback нет call_key');
  }

  const rowIndex = findRowByCallKey_(sheet, headerMap, callKey);

  if (!rowIndex) {
    throw new Error('Не найдена строка по call_key: ' + callKey);
  }

  const now = nowString_();

  const transcriptText = String(body.transcript_text || '');

  let analysis = body.analysis || {};

  if (typeof analysis === 'string') {
    analysis = safeJsonParse_(analysis) || {
      raw: analysis
    };
  }

  const analysisJson = JSON.stringify(analysis, null, 2);

  const summary = String(
    analysis.summary ||
    body.analysis_summary ||
    ''
  );

  const score = String(
    analysis.overall_score ||
    analysis.score_1_5 ||
    analysis.score ||
    body.analysis_score ||
    ''
  );

  const isProblem = normalizeBooleanForSheet_(
    analysis.is_problem_call !== undefined
      ? analysis.is_problem_call
      : body.is_problem_call
  );

  setCellByHeader_(sheet, rowIndex, headerMap, 'transcript_text', transcriptText);
  setCellByHeader_(sheet, rowIndex, headerMap, 'analysis_json', analysisJson);
  setCellByHeader_(sheet, rowIndex, headerMap, 'analysis_summary', summary);
  setCellByHeader_(sheet, rowIndex, headerMap, 'analysis_score', score);
  setCellByHeader_(sheet, rowIndex, headerMap, 'is_problem_call', isProblem);
  setCellByHeader_(sheet, rowIndex, headerMap, 'problem_level', String(analysis.problem_level || ''));
  setCellByHeader_(sheet, rowIndex, headerMap, 'main_strength', String(analysis.main_strength || ''));
  setCellByHeader_(sheet, rowIndex, headerMap, 'main_error', String(analysis.main_error || ''));
  setCellByHeader_(sheet, rowIndex, headerMap, 'recommended_feedback', String(analysis.recommended_feedback || ''));

  upsertEvaluationResults_(callKey, getCellByHeader_(sheet.getRange(rowIndex, 1, 1, sheet.getLastColumn()).getValues()[0], headerMap, 'direction'), analysis);

  setCellByHeader_(sheet, rowIndex, headerMap, 'transcript_status', transcriptText ? 'OK' : '');
  setCellByHeader_(sheet, rowIndex, headerMap, 'ai_status', analysisJson ? 'OK' : '');

  setCellByHeader_(sheet, rowIndex, headerMap, 'n8n_status', 'ANALYZED');
  setCellByHeader_(sheet, rowIndex, headerMap, 'status', 'ANALYZED');
  setCellByHeader_(sheet, rowIndex, headerMap, 'n8n_result_at', now);
  setCellByHeader_(sheet, rowIndex, headerMap, 'error_text', '');
  setCellByHeader_(sheet, rowIndex, headerMap, 'updated_at', now);

  return {
    call_key: callKey,
    row: rowIndex
  };
}

function saveN8nCallError_(body) {
